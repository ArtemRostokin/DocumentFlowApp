<Window x:Class="DocumentFlowApp.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:DocumentFlowApp.WPF.Converters"
        Title="Document Flow App" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <local:NotNullToBooleanConverter x:Key="NotNullToBooleanConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <local:NotNullToVisibilityConverter x:Key="NotNullToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 🎯 ЗАГОЛОВОК -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="📄" FontSize="24" Margin="0,0,10,0"/>
            <TextBlock Text="Document Flow System" FontSize="20" FontWeight="Bold"/>
        </StackPanel>

        <!-- 📊 ОСНОВНОЕ СОДЕРЖИМОЕ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 📋 СПИСОК ДОКУМЕНТОВ -->
            <GroupBox Grid.Column="0" Header="📋 Список документов" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 🎯 ПАНЕЛЬ КНОПОК -->
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button Content="🔄 Обновить" 
                                Command="{Binding LoadDocumentsCommand}"
                                Padding="10,5" Margin="0,0,10,0"/>
                        <Button Content="➕ Создать документ" 
                                Command="{Binding CreateDocumentCommand}"
                                Padding="10,5" Margin="0,0,10,0"/>
                        <Button Content="🗑️ Удалить" 
                                Command="{Binding DeleteDocumentCommand}"
                                Padding="10,5"
                                IsEnabled="{Binding SelectedDocument, Converter={StaticResource NotNullToBooleanConverter}}"/>
                    </StackPanel>

                    <!-- 📋 DATA GRID -->
                    <DataGrid Grid.Row="1" 
                             ItemsSource="{Binding Documents}"
                             SelectedItem="{Binding SelectedDocument}"
                             AutoGenerateColumns="False"
                             IsReadOnly="True"
                             GridLinesVisibility="None"
                             HeadersVisibility="Column"
                             SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Title}" Width="200"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding Type}" Width="100"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="Дата создания" Binding="{Binding CreatedDate, StringFormat=dd.MM.yyyy HH:mm}" Width="120"/>
                            <DataGridTextColumn Header="Автор" Binding="{Binding Author}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </GroupBox>

            <!-- 📊 ИНФОРМАЦИЯ О ВЫБРАННОМ ДОКУМЕНТЕ -->
            <GroupBox Grid.Column="2" Header="📊 Детали документа" Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Выберите документ из списка" 
                                  TextWrapping="Wrap"
                                  FontStyle="Italic"
                                  TextAlignment="Center"
                                  Margin="0,20,0,0"
                                  Visibility="{Binding SelectedDocument, Converter={StaticResource NullToVisibilityConverter}}"/>

                        <StackPanel Visibility="{Binding SelectedDocument, Converter={StaticResource NotNullToVisibilityConverter}}">
                            <TextBlock Text="{Binding SelectedDocument.Title}" 
                                      FontWeight="Bold" FontSize="14" 
                                      Margin="0,0,0,10" TextWrapping="Wrap"/>

                            <TextBlock Text="Описание:" FontWeight="SemiBold" Margin="0,10,0,5"/>
                            <TextBlock Text="{Binding SelectedDocument.Description}" 
                                      TextWrapping="Wrap" Margin="0,0,0,10"/>

                            <TextBlock Text="Тип:" FontWeight="SemiBold" Margin="0,10,0,5"/>
                            <TextBlock Text="{Binding SelectedDocument.Type}" Margin="0,0,0,10"/>

                            <TextBlock Text="Статус:" FontWeight="SemiBold" Margin="0,10,0,5"/>
                            <TextBlock Text="{Binding SelectedDocument.Status}" Margin="0,0,0,10"/>

                            <TextBlock Text="Дата создания:" FontWeight="SemiBold" Margin="0,10,0,5"/>
                            <TextBlock Text="{Binding SelectedDocument.CreatedDate, StringFormat=dd.MM.yyyy HH:mm}" Margin="0,0,0,10"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </GroupBox>
        </Grid>

        <!-- 📊 СТАТУС БАР -->
        <StatusBar Grid.Row="2" Margin="0,10,0,0">
            <StatusBarItem>
                <TextBlock Text="{Binding Documents.Count, StringFormat=Всего документов: {0}}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
