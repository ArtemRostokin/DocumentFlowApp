@model DocumentFlowApp.Web.Models.KanbanBoardPageViewModel
@using DocumentFlowApp.Core.Enums
@using DocumentFlowApp.Core.Security
@{
    Layout = null;
    string IsActive(DocumentType? type) => Model.SelectedType == type ? "bg-white dark:bg-slate-700 text-slate-900 dark:text-white shadow-sm" : "text-slate-600 dark:text-slate-400 hover:text-slate-900 dark:hover:text-white transition-colors";
    var currentUserName = User.Identity?.Name ?? "Пользователь";
    var currentUserRole = User.Claims.FirstOrDefault(c => c.Type == "df_role")?.Value
        ?? User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value
        ?? AppRoles.Employee;
    var normalizedRole = AppRoles.Normalize(currentUserRole) ?? AppRoles.Employee;
    var canManageDocuments = normalizedRole is AppRoles.Admin or AppRoles.Manager;
    var isAdmin = normalizedRole == AppRoles.Admin;
    var isEmployee = normalizedRole == AppRoles.Employee;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>@Model.Title</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#135bec",
                        "background-light": "#f6f6f8",
                        "background-dark": "#101622"
                    },
                    fontFamily: {
                        display: ["Inter", "sans-serif"]
                    }
                }
            }
        };
    </script>
    <style>
        .kanban-scroll::-webkit-scrollbar { height: 8px; width: 8px; }
        .kanban-scroll::-webkit-scrollbar-track { background: transparent; }
        .kanban-scroll::-webkit-scrollbar-thumb { background-color: rgba(156, 163, 175, 0.5); border-radius: 999px; }
        .column-scroll {
            scrollbar-gutter: stable;
        }
        .line-clamp-2-local {
            display: -webkit-box;
            -webkit-line-clamp: 2;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .line-clamp-3-local {
            display: -webkit-box;
            -webkit-line-clamp: 3;
            -webkit-box-orient: vertical;
            overflow: hidden;
        }
        .accent-neutral .column-dot { background: #cbd5e1; }
        .accent-primary .column-dot { background: #135bec; }
        .accent-success .column-dot { background: #16a34a; }
        .accent-danger .column-dot { background: #dc2626; }
        .accent-muted .column-dot { background: #64748b; }
        .type-contract { background: #dbeafe; color: #1d4ed8; }
        .type-invoice { background: #f3e8ff; color: #7e22ce; }
        .type-report { background: #ffedd5; color: #c2410c; }
        .type-order { background: #dcfce7; color: #15803d; }
        .type-application { background: #fee2e2; color: #b91c1c; }
        .type-other { background: #e2e8f0; color: #475569; }
        .status-primary { background: rgba(19, 91, 236, 0.08); color: #135bec; border-color: rgba(19, 91, 236, 0.2); }
        .status-success { background: rgba(22, 163, 74, 0.08); color: #15803d; border-color: rgba(22, 163, 74, 0.2); }
        .status-danger { background: rgba(220, 38, 38, 0.08); color: #b91c1c; border-color: rgba(220, 38, 38, 0.2); }
        .status-muted { background: rgba(100, 116, 139, 0.08); color: #475569; border-color: rgba(100, 116, 139, 0.2); }
        .status-neutral { background: rgba(148, 163, 184, 0.14); color: #475569; border-color: rgba(148, 163, 184, 0.2); }
        .due-danger { color: #dc2626; }
        .due-success { color: #16a34a; }
        .due-neutral { color: #64748b; }
    </style>
</head>
<body class="bg-background-light font-display text-slate-900 min-h-screen flex flex-col overflow-hidden">
    <header class="h-16 bg-white border-b border-slate-200 flex items-center justify-between px-6 shrink-0">
        <div class="flex items-center gap-8">
            <div class="flex items-center gap-2 text-primary">
                <span class="material-symbols-outlined text-2xl">description</span>
                <span class="font-bold text-lg text-slate-900">DocManager</span>
            </div>
            <div class="hidden lg:flex items-center gap-3 rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm">
                <span class="material-symbols-outlined text-[18px] text-primary">space_dashboard</span>
                <span class="font-medium text-slate-700">@Model.ViewModeLabel</span>
            </div>
        </div>
        <div class="flex items-center gap-6">
            <form method="get" asp-action="Index" class="relative hidden sm:block w-72">
                @if (Model.SelectedType.HasValue)
                {
                    <input type="hidden" name="type" value="@Model.SelectedType" />
                }
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">search</span>
                <input class="w-full bg-slate-100 border-none rounded-lg pl-10 pr-4 py-2 text-sm focus:ring-2 focus:ring-primary text-slate-900 placeholder-slate-500"
                       name="q"
                       value="@Model.SearchQuery"
                       placeholder="Поиск по документам..." />
            </form>
            <div class="flex items-center gap-4">
                <button class="p-2 text-slate-500 hover:text-slate-700 transition-colors relative" type="button">
                    <span class="material-symbols-outlined">notifications</span>
                    <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-red-500 rounded-full"></span>
                </button>
                <div class="flex items-center gap-3 border-l border-slate-200 pl-4">
                    <div class="text-right hidden lg:block">
                        <div class="text-sm font-medium text-slate-900">@currentUserName</div>
                        <div class="text-xs text-slate-500">@normalizedRole</div>
                    </div>
                    <div class="w-8 h-8 rounded-full bg-slate-200 flex items-center justify-center text-xs font-semibold text-slate-600">DF</div>
                    <form method="post" asp-controller="Account" asp-action="Logout">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="text-xs text-slate-500 hover:text-slate-800 transition-colors">Выйти</button>
                    </form>
                </div>
            </div>
        </div>
    </header>

    <main class="flex-1 flex flex-col h-full overflow-hidden w-full">
        <div class="px-6 py-3 flex flex-col gap-3 shrink-0 bg-white/70 backdrop-blur-sm border-b border-slate-200/80">
            <div>
                <h1 class="text-2xl font-bold text-slate-900">@Model.Title</h1>
                <p class="mt-1 text-sm text-slate-500">@Model.PeriodLabel</p>
                <p class="mt-1.5 max-w-3xl text-sm leading-6 text-slate-600">@Model.ViewModeDescription</p>
            </div>
            <div class="grid gap-3 xl:grid-cols-[minmax(0,1fr)_auto] xl:items-start">
                <div class="flex min-w-0 flex-wrap items-center gap-2">
                    <div class="flex shrink-0 bg-slate-100 rounded-lg p-1">
                        <a asp-action="Index" asp-route-q="@Model.SearchQuery" class="px-3 py-1.5 text-sm font-medium rounded-md @(IsActive(null))">Все</a>
                        <a asp-action="Index" asp-route-type="@DocumentType.Contract" asp-route-q="@Model.SearchQuery" class="px-3 py-1.5 text-sm font-medium rounded-md @(IsActive(DocumentType.Contract))">Договоры</a>
                        <a asp-action="Index" asp-route-type="@DocumentType.Invoice" asp-route-q="@Model.SearchQuery" class="px-3 py-1.5 text-sm font-medium rounded-md @(IsActive(DocumentType.Invoice))">Счета</a>
                    </div>
                    <div class="hidden min-w-0 lg:flex items-center gap-2 text-xs text-slate-400">
                        <span class="truncate">Колонки прокручиваются отдельно</span>
                        <span class="w-1 h-1 rounded-full bg-slate-300"></span>
                        <span class="truncate">Откройте карточку двойным кликом</span>
                    </div>
                </div>

                <div class="flex flex-wrap items-center gap-2 xl:justify-end">
                    @if (isEmployee)
                    {
                        <a asp-controller="Documents"
                           asp-action="MyTasks"
                           class="border border-emerald-200 bg-emerald-50 text-emerald-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-emerald-100 transition-colors">
                            Список задач
                        </a>
                    }
                    @if (isAdmin)
                    {
                        <a asp-controller="Admin"
                           asp-action="Index"
                           class="border border-slate-300 bg-white text-slate-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors">
                            Админка
                        </a>
                    }
                    @if (canManageDocuments)
                    {
                        <a asp-controller="Documents"
                           asp-action="ApprovalQueue"
                           class="border border-blue-200 bg-blue-50 text-blue-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-blue-100 transition-colors">
                            Очередь согласования
                        </a>
                        <a asp-controller="Documents"
                           asp-action="UploadIncoming"
                           class="border border-slate-300 bg-white text-slate-700 px-4 py-2 rounded-lg text-sm font-medium hover:bg-slate-50 transition-colors">
                            Загрузить входящие
                        </a>
                        <a asp-controller="Documents"
                           asp-action="Create"
                           class="inline-flex bg-primary text-white px-4 py-2 rounded-lg text-sm font-medium hover:bg-primary/90 transition-colors shadow-sm shadow-primary/20">
                            Создать по шаблону
                        </a>
                    }
                </div>

                <div class="flex flex-wrap items-center gap-2 xl:col-span-2">
                    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-600">
                        @Model.TotalLabel: @Model.TotalDocuments
                    </span>
                    <span class="rounded-full bg-amber-50 px-3 py-1 text-xs font-medium text-amber-700">
                        На согласовании: @Model.ApprovalCount
                    </span>
                    <span class="rounded-full bg-blue-50 px-3 py-1 text-xs font-medium text-blue-700">
                        В работе: @Model.InWorkCount
                    </span>
                    <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-medium text-emerald-700">
                        Завершено: @Model.CompletedCount
                    </span>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Notice))
        {
            <div class="mx-6 mt-4 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
                @Model.Notice
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="mx-6 mt-4 rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
                @Model.SuccessMessage
            </div>
        }

        <div id="kanbanViewport" class="min-h-0 overflow-x-auto overflow-y-hidden kanban-scroll px-6 py-4">
            <div class="flex h-full min-h-0 gap-5 items-stretch pb-2">
                @foreach (var column in Model.Columns)
                {
                    <section class="w-80 shrink-0 flex h-full min-h-0 flex-col rounded-2xl border border-slate-200 bg-slate-100/70 p-2 @column.AccentClass">
                        <div class="sticky top-0 z-10 mb-2 flex items-center justify-between rounded-xl bg-background-light/95 px-2 py-2 backdrop-blur-sm">
                            <div class="flex items-center gap-2">
                                <div class="column-dot w-2 h-2 rounded-full"></div>
                                <h3 class="font-semibold text-slate-700">@column.Title</h3>
                                <span class="px-2 py-0.5 rounded-full bg-slate-200 text-xs font-medium text-slate-600">@column.Documents.Count</span>
                            </div>
                            <button class="text-slate-400 hover:text-slate-600" type="button">
                                <span class="material-symbols-outlined text-sm">more_horiz</span>
                            </button>
                        </div>

                        @if (column.IsEmptyPlaceholder)
                        {
                            <div class="flex min-h-0 flex-1 items-center justify-center overflow-y-auto rounded-xl border-2 border-dashed border-slate-200 bg-slate-50/80 p-4">
                                <div class="text-center p-4">
                                    <span class="material-symbols-outlined text-3xl text-slate-300 mb-2">inventory_2</span>
                                    <p class="text-sm text-slate-400">Нет документов в этой колонке</p>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div class="column-scroll flex-1 min-h-0 overflow-y-auto kanban-scroll space-y-2 pr-1 pb-1 overscroll-contain"
                                 data-kanban-column
                                 data-status="@column.Status">
                                @if (column.Documents.Count == 0)
                                {
                                    <div class="bg-slate-50 border border-dashed border-slate-200 p-4 rounded-xl text-sm text-slate-400">
                                        Пока пусто
                                    </div>
                                }

                                @foreach (var card in column.Documents)
                                {
                                    <article class="bg-white p-3 rounded-xl shadow-sm border border-slate-200 hover:border-primary/50 transition-colors group cursor-grab active:cursor-grabbing"
                                             draggable="true"
                                             data-kanban-card
                                             data-document-id="@card.Id"
                                             data-edit-url="@Url.Action("Edit", "Documents", new { id = card.Id })">
                                        <div class="flex justify-between items-start mb-2 gap-2">
                                            <span class="px-2.5 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider @card.TypeClass">@card.TypeLabel</span>
                                            <span class="flex items-center gap-1 px-2 py-0.5 rounded text-[11px] font-medium border @card.StatusClass">
                                                <span class="material-symbols-outlined text-[12px] @(card.StatusIcon == "autorenew" ? "animate-spin" : null)">@card.StatusIcon</span>
                                                @card.StatusLabel
                                            </span>
                                        </div>

                                        <div class="flex items-start justify-between gap-3">
                                            <h4 class="mb-1 line-clamp-2-local font-medium leading-tight text-slate-900">@card.Title</h4>
                                            <a class="text-slate-300 hover:text-primary transition-colors"
                                               title="Открыть"
                                               href="@Url.Action("Edit", "Documents", new { id = card.Id })">
                                                <span class="material-symbols-outlined text-[18px]">open_in_new</span>
                                            </a>
                                        </div>
                                        <p class="mb-2 text-[13px] text-slate-500 line-clamp-2-local">@card.Subtitle</p>

                                        <div class="mb-2 flex items-center gap-2 rounded-lg border border-slate-200 bg-slate-50 px-2.5 py-2">
                                            <span class="material-symbols-outlined text-primary text-sm @(card.Progress == 0 ? "animate-pulse" : null)">monitoring</span>
                                            <div class="flex-1">
                                                <div class="mb-1 flex justify-between text-[11px]">
                                                    <span class="text-slate-600">@card.ProgressLabel</span>
                                                    <span class="text-slate-900 font-medium">@card.Progress%</span>
                                                </div>
                                                <div class="h-1 bg-slate-200 rounded-full overflow-hidden">
                                                    <div class="h-full bg-primary rounded-full" style="width:@(card.Progress)%"></div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="mb-2 flex items-start gap-2 rounded-lg bg-slate-50 px-2.5 py-2 text-[11px] leading-5 text-slate-600">
                                            <span class="material-symbols-outlined mt-0.5 text-[14px] text-slate-400">info</span>
                                            <span class="line-clamp-2-local">@card.StageHint</span>
                                        </div>

                                        <div class="mt-auto flex items-center justify-between border-t border-slate-100 pt-2">
                                            <div class="flex items-center gap-1.5 text-slate-500">
                                                <div class="w-6 h-6 rounded-full bg-slate-200 flex items-center justify-center text-[10px] font-bold text-slate-600">
                                                    @(card.Author.Length >= 2 ? card.Author[..2].ToUpperInvariant() : card.Author.ToUpperInvariant())
                                                </div>
                                                <span class="text-xs">@card.Author</span>
                                            </div>
                                            <div class="flex items-center gap-1 text-xs @card.DueClass">
                                                <span class="material-symbols-outlined text-[14px]">calendar_today</span>
                                                <span>@card.DueLabel</span>
                                            </div>
                                        </div>
                                    </article>
                                }
                            </div>
                        }
                    </section>
                }
            </div>
        </div>
    </main>

    <form id="antiForgeryForm" method="post" class="hidden">
        @Html.AntiForgeryToken()
    </form>

    <div id="kanbanToast" class="hidden fixed bottom-6 right-6 max-w-sm rounded-xl border border-slate-200 bg-white px-4 py-3 shadow-lg text-sm text-slate-700"></div>

    <script>
        (function () {
            const toast = document.getElementById("kanbanToast");
            const tokenInput = document.querySelector("#antiForgeryForm input[name='__RequestVerificationToken']");
            const token = tokenInput ? tokenInput.value : "";
            const kanbanViewport = document.getElementById("kanbanViewport");

            function showToast(message) {
                if (!toast) return;
                toast.textContent = message;
                toast.classList.remove("hidden");
                window.clearTimeout(showToast._t);
                showToast._t = window.setTimeout(() => toast.classList.add("hidden"), 4000);
            }

            function syncKanbanViewportHeight() {
                if (!kanbanViewport) return;
                const rect = kanbanViewport.getBoundingClientRect();
                const bottomGap = 12;
                const available = Math.max(320, window.innerHeight - rect.top - bottomGap);
                kanbanViewport.style.height = `${available}px`;
            }

            syncKanbanViewportHeight();
            window.addEventListener("resize", syncKanbanViewportHeight);

            let draggingCard = null;

            document.addEventListener("dragstart", (e) => {
                const card = e.target && e.target.closest ? e.target.closest("[data-kanban-card]") : null;
                if (!card) return;
                draggingCard = card;
                e.dataTransfer.setData("text/plain", card.getAttribute("data-document-id") || "");
                e.dataTransfer.effectAllowed = "move";
            });

            document.addEventListener("dragend", () => {
                draggingCard = null;
            });

            document.querySelectorAll("[data-kanban-column]").forEach((columnEl) => {
                columnEl.addEventListener("dragover", (e) => {
                    e.preventDefault();
                    e.dataTransfer.dropEffect = "move";
                });

                columnEl.addEventListener("drop", async (e) => {
                    e.preventDefault();

                    const documentId = e.dataTransfer.getData("text/plain");
                    const newStatus = columnEl.getAttribute("data-status");
                    if (!documentId || !newStatus) return;

                    if (!draggingCard) return;

                    // Оптимистично перемещаем карточку в UI
                    const originalParent = draggingCard.parentElement;
                    const originalNextSibling = draggingCard.nextElementSibling;
                    columnEl.prepend(draggingCard);

                    try {
                        const resp = await fetch(`/Documents/${documentId}/status`, {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                                "RequestVerificationToken": token
                            },
                            body: JSON.stringify({ newStatus })
                        });

                        if (!resp.ok) {
                            let msg = "Не удалось изменить статус.";
                            try {
                                const data = await resp.json();
                                if (data && data.message) msg = data.message;
                            } catch { }

                            // Откат UI
                            if (originalParent) {
                                if (originalNextSibling) originalParent.insertBefore(draggingCard, originalNextSibling);
                                else originalParent.appendChild(draggingCard);
                            }
                            showToast(msg);
                            return;
                        }

                        // Перезагружаем, чтобы счетчики и колонки остались консистентными
                        window.location.reload();
                    } catch (err) {
                        // Откат UI
                        if (originalParent) {
                            if (originalNextSibling) originalParent.insertBefore(draggingCard, originalNextSibling);
                            else originalParent.appendChild(draggingCard);
                        }
                        showToast("Ошибка сети при смене статуса.");
                    }
                });
            });

            // Быстрый переход к редактированию по двойному клику
            document.addEventListener("dblclick", (e) => {
                const card = e.target && e.target.closest ? e.target.closest("[data-kanban-card]") : null;
                if (!card) return;
                const url = card.getAttribute("data-edit-url");
                if (url) window.location.href = url;
            });
        })();
    </script>

</body>
</html>
