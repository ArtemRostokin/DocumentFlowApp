@model DocumentFlowApp.Web.Models.LoginViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html class="light" lang="ru">
<head>
    <meta charset="utf-8">
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <title>DocManager - Вход в систему</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet">
    <style>
        body {
            font-family: "Inter", sans-serif;
            background: radial-gradient(circle at top left, #f8fafc 0%, #f1f5f9 100%);
        }
        .glass-nav {
            background: rgba(255, 255, 255, 0.5);
            backdrop-filter: blur(8px);
        }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-center text-slate-800 selection:bg-slate-200">
    <header class="fixed top-0 w-full z-50 glass-nav border-b border-slate-200/10 shadow-sm flex justify-between items-center px-6 py-3">
        <div class="text-xl font-bold tracking-tight text-slate-800">DocManager</div>
    </header>

    <main class="w-full max-w-md px-6 py-12">
        <div class="bg-white p-8 md:p-10 rounded-xl shadow-sm border border-slate-200/20">
            <div class="flex flex-col items-center mb-8">
                <div class="w-12 h-12 bg-slate-600 rounded-lg flex items-center justify-center mb-6 shadow-sm">
                    <span class="material-symbols-outlined text-white text-3xl">description</span>
                </div>
                <h1 class="text-2xl font-bold tracking-tight mb-2">Вход в систему</h1>
                <p class="text-sm text-slate-500 text-center">Управляйте вашими документами в защищенном архиве Slate Archive</p>
            </div>

            <form method="post" asp-action="Login" class="space-y-6">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="ReturnUrl" />

                @if (!ViewData.ModelState.IsValid)
                {
                    <div asp-validation-summary="ModelOnly" class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700"></div>
                }

                <div class="space-y-2">
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-600" asp-for="Email">Электронная почта</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">mail</span>
                        <input asp-for="Email" class="w-full pl-10 pr-4 py-3 bg-slate-100 border border-slate-300/30 rounded-lg focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500 outline-none transition-all text-sm placeholder:text-slate-400" placeholder="example@docmanager.ru" type="email" />
                    </div>
                    <span asp-validation-for="Email" class="text-xs text-red-600"></span>
                </div>

                <div class="space-y-2">
                    <label class="block text-xs font-bold uppercase tracking-wider text-slate-600" asp-for="Password">Пароль</label>
                    <div class="relative">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">lock</span>
                        <input asp-for="Password" class="w-full pl-10 pr-4 py-3 bg-slate-100 border border-slate-300/30 rounded-lg focus:ring-2 focus:ring-slate-500/20 focus:border-slate-500 outline-none transition-all text-sm placeholder:text-slate-400" placeholder="••••••••" type="password" />
                    </div>
                    <span asp-validation-for="Password" class="text-xs text-red-600"></span>
                </div>

                <div class="flex items-center">
                    <input asp-for="RememberMe" class="w-4 h-4 text-slate-600 border-slate-300 rounded focus:ring-slate-500/20 transition-all cursor-pointer" type="checkbox" />
                    <label class="ml-2 text-sm text-slate-500 cursor-pointer select-none" asp-for="RememberMe">Запомнить меня</label>
                </div>

                <button class="w-full bg-slate-600 hover:bg-slate-700 text-white font-semibold py-3.5 rounded-lg shadow-sm transition-all active:scale-[0.98] flex items-center justify-center gap-2" type="submit">
                    <span>Войти</span>
                    <span class="material-symbols-outlined text-lg">login</span>
                </button>
            </form>
        </div>
    </main>
</body>
</html>
