@model DocumentFlowApp.Web.Models.AdminDashboardPageViewModel
@{
    ViewData["Title"] = "Администрирование";
}

<div class="container py-4">
    <div class="mb-4">
        <h1 class="h3 mb-2">Администрирование</h1>
        <p class="text-muted mb-0">Центр управления пользователями, маршрутами, номенклатурой и журналом системных действий.</p>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-lg-3 col-md-6"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small mb-1">Пользователи</div><div class="display-6 mb-0">@Model.TotalUsers</div><div class="small text-muted mt-2">Активных: @Model.ActiveUsers</div></div></div></div>
        <div class="col-lg-3 col-md-6"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small mb-1">Документы</div><div class="display-6 mb-0">@Model.TotalDocuments</div><div class="small text-muted mt-2">На согласовании: @Model.PendingApprovalDocuments</div></div></div></div>
        <div class="col-lg-3 col-md-6"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small mb-1">Исполнение</div><div class="display-6 mb-0">@Model.InWorkDocuments</div><div class="small text-muted mt-2">Завершено: @Model.CompletedDocuments</div></div></div></div>
        <div class="col-lg-3 col-md-6"><div class="card shadow-sm h-100"><div class="card-body"><div class="text-muted small mb-1">Аудит за сегодня</div><div class="display-6 mb-0">@Model.AuditEventsToday</div><div class="small text-muted mt-2">Активных дел номенклатуры: @Model.ActiveNomenclatureCases</div></div></div></div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-6 col-xl-4"><div class="card h-100 shadow-sm"><div class="card-body d-flex flex-column"><h2 class="h5">Пользователи</h2><p class="text-muted flex-grow-1">Создание учетных записей, смена ролей, управление доступом и сброс паролей.</p><a class="btn btn-primary" asp-action="Users">Открыть раздел</a></div></div></div>
        <div class="col-md-6 col-xl-4"><div class="card h-100 shadow-sm"><div class="card-body d-flex flex-column"><h2 class="h5">Шаблоны документов</h2><p class="text-muted flex-grow-1">Типовые карточки документов, наборы полей и базовые сценарии создания по шаблону.</p><a class="btn btn-primary" asp-action="Templates">Открыть раздел</a></div></div></div>
        <div class="col-md-6 col-xl-4"><div class="card h-100 shadow-sm"><div class="card-body d-flex flex-column"><h2 class="h5">Маршруты</h2><p class="text-muted flex-grow-1">Шаблоны согласования, бизнес-роли и настройка шагов для разных типов документов.</p><a class="btn btn-primary" asp-action="Routes">Открыть раздел</a></div></div></div>
        <div class="col-md-6 col-xl-4"><div class="card h-100 shadow-sm"><div class="card-body d-flex flex-column"><h2 class="h5">Номенклатура</h2><p class="text-muted flex-grow-1">Дела номенклатуры и правила автопривязки документов по типу и подразделению.</p><a class="btn btn-primary" asp-action="Nomenclature">Открыть раздел</a></div></div></div>
        <div class="col-md-6 col-xl-4"><div class="card h-100 shadow-sm"><div class="card-body d-flex flex-column"><h2 class="h5">Аудит</h2><p class="text-muted flex-grow-1">Журнал системных и документных действий с фильтрацией по событию и документу.</p><a class="btn btn-primary" asp-action="Audit">Открыть раздел</a></div></div></div>
        <div class="col-md-6 col-xl-4"><div class="card h-100 shadow-sm"><div class="card-body d-flex flex-column"><h2 class="h5">Отчеты</h2><p class="text-muted flex-grow-1">Сводка по документам за период: статусы, типы, просрочки и текущая нагрузка.</p><a class="btn btn-primary" asp-action="Reports">Сформировать отчет</a></div></div></div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center mb-3 gap-2 flex-wrap">
                <div>
                    <h2 class="h5 mb-1">Требует внимания</h2>
                    <div class="small text-muted">Здесь собраны точки, которые стоит проверить администратору в первую очередь.</div>
                </div>
                <a asp-action="Audit" class="btn btn-outline-secondary btn-sm">Открыть аудит</a>
            </div>

            <div class="row g-3">
                @foreach (var item in Model.AttentionItems)
                {
                    <div class="col-md-6 col-xl-4">
                        <div class="border rounded-3 p-3 h-100">
                            <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                <div class="fw-semibold">@item.Title</div>
                                <span class="badge @item.BadgeClass">@item.Value</span>
                            </div>
                            <div class="small text-muted">@item.Description</div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
