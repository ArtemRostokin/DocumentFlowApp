@{
    ViewData["Title"] = "Администрирование";
}

<div class="container py-4">
    <div class="mb-4">
        <h1 class="h3 mb-2">Администрирование</h1>
        <p class="text-muted mb-0">Системные экраны для настройки ролей, маршрутов, номенклатуры и аудита.</p>
    </div>

    <div class="row g-3">
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Маршруты</h2>
                    <p class="text-muted">Шаблоны согласования и шаги маршрута документа.</p>
                    <a class="btn btn-primary" asp-action="Routes">Открыть</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Номенклатура</h2>
                    <p class="text-muted">Дела номенклатуры и правила архивирования.</p>
                    <a class="btn btn-primary" asp-action="Nomenclature">Открыть</a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h2 class="h5">Аудит</h2>
                    <p class="text-muted">Просмотр истории критичных действий в системе.</p>
                    <a class="btn btn-primary" asp-action="Audit">Открыть</a>
                </div>
            </div>
        </div>
    </div>
</div>
