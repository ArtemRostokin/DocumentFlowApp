@model DocumentFlowApp.Web.Models.MyTasksPageViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Мои задачи - DocManager</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>body { font-family: "Inter", sans-serif; }</style>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen">
    <header class="border-b border-slate-200 bg-white">
        <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
            <div>
                <div class="text-sm font-medium text-slate-500">Контур исполнителя</div>
                <h1 class="mt-1 text-2xl font-bold tracking-tight">Мои задачи</h1>
                <p class="mt-1 text-sm text-slate-500">@Model.EmployeeName, здесь отображаются документы, назначенные вам в работу.</p>
            </div>
            <a asp-controller="Home" asp-action="Index" class="rounded-lg border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">На доску</a>
        </div>
    </header>

    <main class="mx-auto max-w-7xl px-6 py-8 space-y-6">
        <section class="grid grid-cols-1 gap-4 md:grid-cols-3">
            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Всего активных задач</div>
                <div class="mt-2 text-3xl font-bold text-slate-900">@Model.TotalTasks</div>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Готовы к старту</div>
                <div class="mt-2 text-3xl font-bold text-blue-700">@Model.ApprovedTasks</div>
            </div>
            <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <div class="text-xs font-bold uppercase tracking-wider text-slate-500">В работе</div>
                <div class="mt-2 text-3xl font-bold text-emerald-700">@Model.InWorkTasks</div>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(Model.SuccessMessage))
        {
            <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">@Model.SuccessMessage</div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">@Model.ErrorMessage</div>
        }

        @if (Model.Tasks.Count == 0)
        {
            <section class="rounded-2xl border border-dashed border-slate-300 bg-white px-8 py-16 text-center">
                <span class="material-symbols-outlined text-5xl text-slate-300">task_alt</span>
                <h2 class="mt-4 text-xl font-semibold">Назначенных задач пока нет</h2>
                <p class="mt-2 text-sm text-slate-500">Когда менеджер назначит вам документ, он появится здесь.</p>
            </section>
        }
        else
        {
            <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
                @foreach (var task in Model.Tasks)
                {
                    <section class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
                        <div class="flex items-start justify-between gap-4">
                            <div>
                                <div class="flex flex-wrap items-center gap-2">
                                    <span class="rounded-md bg-slate-100 px-2.5 py-1 text-[11px] font-bold uppercase tracking-wider text-slate-600">@task.TypeLabel</span>
                                    <span class="rounded-md bg-blue-50 px-2.5 py-1 text-[11px] font-bold uppercase tracking-wider text-blue-700">@task.StatusLabel</span>
                                </div>
                                <h2 class="mt-3 text-xl font-semibold text-slate-900">@task.Title</h2>
                                <p class="mt-2 text-sm leading-6 text-slate-600">@task.Description</p>
                            </div>
                            <a asp-action="Edit" asp-route-id="@task.Id" class="shrink-0 rounded-lg border border-slate-300 px-3 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Открыть</a>
                        </div>

                        <div class="mt-5 rounded-xl bg-slate-50 px-4 py-3 text-sm text-slate-600">
                            <span class="font-semibold text-slate-900">Срок:</span> @task.DueDateLabel
                        </div>

                        <div class="mt-5 flex flex-wrap gap-3">
                            @if (task.CanStartWork)
                            {
                                <form method="post" action="/Documents/@task.Id/start-work">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex items-center gap-2 rounded-xl bg-blue-600 px-4 py-3 text-sm font-semibold text-white hover:bg-blue-700">
                                        <span class="material-symbols-outlined text-[18px]">play_arrow</span>
                                        Начать работу
                                    </button>
                                </form>
                            }
                            @if (task.CanComplete)
                            {
                                <form method="post" action="/Documents/@task.Id/complete-work">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="inline-flex items-center gap-2 rounded-xl bg-emerald-600 px-4 py-3 text-sm font-semibold text-white hover:bg-emerald-700">
                                        <span class="material-symbols-outlined text-[18px]">task_alt</span>
                                        Завершить
                                    </button>
                                </form>
                            }
                        </div>
                    </section>
                }
            </div>
        }
    </main>
</body>
</html>