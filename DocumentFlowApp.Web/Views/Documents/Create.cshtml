@model DocumentFlowApp.Web.Models.CreateDocumentPageViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html class="light" lang="ru">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Создание документа - DocManager</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <style>
        body { font-family: "Inter", sans-serif; }
        .material-symbols-outlined {
            font-variation-settings: "FILL" 0, "wght" 400, "GRAD" 0, "opsz" 24;
        }
    </style>
</head>
<body class="bg-slate-50 text-slate-800 min-h-screen flex flex-col">
    <nav class="fixed top-0 w-full z-50 bg-slate-50/80 backdrop-blur-md border-b border-slate-200 shadow-sm">
        <div class="flex justify-between items-center px-6 h-16 w-full max-w-full mx-auto">
            <div class="text-xl font-bold tracking-tight text-slate-800">DocManager</div>
            <div class="hidden md:flex items-center gap-8 text-sm font-medium tracking-tight">
                <a class="text-slate-500 hover:text-slate-800 transition-colors duration-200" asp-controller="Home" asp-action="Index">Доска</a>
                <a class="text-slate-500 hover:text-slate-800 transition-colors duration-200" href="#">Аналитика</a>
                <a class="text-slate-500 hover:text-slate-800 transition-colors duration-200" href="#">Профиль</a>
            </div>
        </div>
    </nav>

    <main class="flex-grow pt-24 pb-12 px-6 flex justify-center">
        <div class="w-full max-w-4xl">
            <div class="mb-8">
                <h1 class="text-3xl font-bold tracking-tight">Создание документа</h1>
                <p class="text-slate-500 mt-1 text-sm">Заполните карточку и при необходимости прикрепите файл. После сохранения документ попадет в статус "Черновик".</p>
            </div>

            <form method="post" asp-action="Create" enctype="multipart/form-data" class="space-y-8" novalidate>
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="rounded-lg border border-red-200 bg-red-50 px-3 py-2 text-sm text-red-700"></div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="md:col-span-2 bg-white p-8 rounded-xl border border-slate-300 shadow-sm flex flex-col items-center justify-center border-dashed border-2 min-h-[240px]">
                        <div class="w-12 h-12 bg-slate-100 rounded-full flex items-center justify-center mb-4">
                            <span class="material-symbols-outlined text-slate-600">cloud_upload</span>
                        </div>
                        <label asp-for="File" class="text-slate-800 font-medium text-center cursor-pointer">Выберите PDF-файл документа</label>
                        <input asp-for="File" accept="application/pdf" class="mt-3 w-full max-w-sm text-sm text-slate-600 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-slate-600 file:text-white hover:file:bg-slate-700" />
                        <span asp-validation-for="File" class="text-xs text-red-600 mt-2"></span>
                        <p class="text-slate-500 text-xs mt-2 uppercase tracking-widest font-bold">PDF до 25MB</p>
                    </div>
                    <div class="md:col-span-1 bg-slate-100 p-6 rounded-xl border border-slate-300 flex flex-col justify-between">
                        <div>
                            <span class="material-symbols-outlined text-sky-500 mb-2">smart_toy</span>
                            <h3 class="text-sm font-bold uppercase tracking-widest text-slate-600">AI-подсказка</h3>
                            <p class="text-xs text-slate-500 mt-2">На этом этапе AI используется как вспомогательный слой: помогает выделять реквизиты и подсказывать тип документа при загрузке.</p>
                        </div>
                    </div>
                </div>

                <div class="bg-white p-8 rounded-xl border border-slate-300 shadow-sm space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-1.5 md:col-span-2">
                            <label asp-for="Title" class="text-[10px] uppercase font-bold tracking-widest text-slate-500 block">Название документа</label>
                            <input asp-for="Title" class="w-full bg-slate-50 border-slate-300 rounded-lg text-sm px-4 py-2.5 focus:ring-1 focus:ring-slate-600 focus:border-slate-600 transition-all outline-none" placeholder="Например: Договор поставки №42" />
                            <span asp-validation-for="Title" class="text-xs text-red-600"></span>
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="Type" class="text-[10px] uppercase font-bold tracking-widest text-slate-500 block">Тип документа</label>
                            <select asp-for="Type" asp-items="Html.GetEnumSelectList<DocumentFlowApp.Core.Enums.DocumentType>()" class="w-full bg-slate-50 border-slate-300 rounded-lg text-sm px-4 py-2.5 focus:ring-1 focus:ring-slate-600 appearance-none outline-none">
                                <option value="">Выберите тип документа</option>
                            </select>
                            <span asp-validation-for="Type" class="text-xs text-red-600"></span>
                        </div>

                        <div class="space-y-1.5">
                            <label asp-for="DueDate" class="text-[10px] uppercase font-bold tracking-widest text-slate-500 block">Срок исполнения</label>
                            <input asp-for="DueDate" class="w-full bg-slate-50 border-slate-300 rounded-lg text-sm px-4 py-2.5 focus:ring-1 focus:ring-slate-600 outline-none" />
                            <span asp-validation-for="DueDate" class="text-xs text-red-600"></span>
                        </div>
                    </div>

                    <div class="space-y-1.5">
                        <label asp-for="Description" class="text-[10px] uppercase font-bold tracking-widest text-slate-500 block">Описание</label>
                        <textarea asp-for="Description" rows="4" class="w-full bg-slate-50 border-slate-300 rounded-lg text-sm px-4 py-2.5 focus:ring-1 focus:ring-slate-600 outline-none" placeholder="Кратко опишите назначение документа и его содержание"></textarea>
                        <span asp-validation-for="Description" class="text-xs text-red-600"></span>
                    </div>

                    <div class="pt-4 border-t border-slate-200 flex flex-wrap items-center justify-between gap-6">
                        <div class="space-y-1.5">
                            <label asp-for="Priority" class="text-[10px] uppercase font-bold tracking-widest text-slate-500 block">Приоритет</label>
                            <select asp-for="Priority" class="bg-slate-50 border-slate-300 rounded-lg text-sm px-4 py-2.5 outline-none">
                                <option value="">Не выбран</option>
                                <option value="1">Низкий</option>
                                <option value="2">Средний</option>
                                <option value="3">Высокий</option>
                            </select>
                            <span asp-validation-for="Priority" class="text-xs text-red-600"></span>
                        </div>

                        <div class="space-y-1.5 flex-grow max-w-md">
                            <label asp-for="Tags" class="text-[10px] uppercase font-bold tracking-widest text-slate-500 block">Теги</label>
                            <input asp-for="Tags" class="w-full bg-slate-50 border-slate-300 rounded-lg text-sm px-4 py-2.5 outline-none" placeholder="Например: финансы, договор, поставщик" />
                            <span asp-validation-for="Tags" class="text-xs text-red-600"></span>
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-end gap-4 pt-4">
                    <a asp-controller="Home" asp-action="Index" class="px-8 py-3 rounded-xl text-sm font-bold uppercase tracking-widest text-slate-500 hover:text-slate-800 transition-colors">Отмена</a>
                    <button class="px-10 py-3 rounded-xl bg-slate-600 text-white text-sm font-bold uppercase tracking-widest shadow-sm hover:bg-slate-700 transition-all" type="submit">Создать документ</button>
                </div>
            </form>
        </div>
    </main>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>