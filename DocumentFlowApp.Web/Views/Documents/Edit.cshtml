@model DocumentFlowApp.Web.Models.EditDocumentPageViewModel
@using DocumentFlowApp.Core.Enums
@using DocumentFlowApp.Core.Security
@{
    Layout = null;
    var currentUserRole = User.Claims.FirstOrDefault(c => c.Type == "df_role")?.Value
        ?? User.Claims.FirstOrDefault(c => c.Type == System.Security.Claims.ClaimTypes.Role)?.Value
        ?? AppRoles.Employee;
    var normalizedRole = AppRoles.Normalize(currentUserRole) ?? AppRoles.Employee;
    var isEmployeeRole = normalizedRole == AppRoles.Employee;
    var isManagerOrAdminRole = normalizedRole is AppRoles.Admin or AppRoles.Manager;
    var canAssignExecutor = normalizedRole is AppRoles.Admin or AppRoles.Manager;
    var hasUserActions = Model.CanApprove || Model.CanRework || Model.CanStartWork || Model.CanComplete;
    var statusText = (Model.Status ?? string.Empty).Trim();
    var isExecutionStage = statusText.Equals("Approved", StringComparison.OrdinalIgnoreCase)
        || statusText.Equals("InWork", StringComparison.OrdinalIgnoreCase)
        || statusText.Equals("Completed", StringComparison.OrdinalIgnoreCase)
        || statusText.Equals("Approved".ToLowerInvariant(), StringComparison.OrdinalIgnoreCase)
        || statusText.Equals("InWork".ToLowerInvariant(), StringComparison.OrdinalIgnoreCase)
        || statusText.Equals("Completed".ToLowerInvariant(), StringComparison.OrdinalIgnoreCase);
    var hasExecutionData = Model.ExecutionStartedAt.HasValue
        || Model.ExecutionCompletedAt.HasValue
        || !string.IsNullOrWhiteSpace(Model.ExecutionComment)
        || !string.IsNullOrWhiteSpace(Model.ExecutionResult)
        || !string.IsNullOrWhiteSpace(Model.ExecutionFileUrl);
    var hasExecutionBlock = (isEmployeeRole && (Model.CanStartWork || Model.CanSaveExecutionProgress || Model.CanComplete || isExecutionStage))
        || (isManagerOrAdminRole && (hasExecutionData || statusText.Equals("Completed", StringComparison.OrdinalIgnoreCase)))
        || Model.ExecutionStartedAt.HasValue
        || Model.ExecutionCompletedAt.HasValue
        || !string.IsNullOrWhiteSpace(Model.ExecutionComment)
        || !string.IsNullOrWhiteSpace(Model.ExecutionResult)
        || !string.IsNullOrWhiteSpace(Model.ExecutionFileUrl);
    var hasSourceFile = !string.IsNullOrWhiteSpace(Model.FileUrl);
    var hasExecutionFile = !string.IsNullOrWhiteSpace(Model.ExecutionFileUrl);
    var showDedicatedExecutionFileBlock = hasExecutionFile && hasSourceFile;
    var previewUrl = hasSourceFile ? Model.FileUrl : Model.ExecutionFileUrl;
    var previewKind = hasSourceFile ? Model.FileKind : Model.ExecutionFileKind;
    var previewTitle = hasSourceFile ? "Исходный файл документа" : hasExecutionFile ? "Итоговый файл исполнения" : "Превью документа";
    var showAiPanel = Model.CanEditDocument && Model.AiSuggestions.Count > 0;
    var showAssignmentSection = canAssignExecutor || !string.IsNullOrWhiteSpace(Model.Assignment.AssignedUserName);
    var showNomenclatureSection = canAssignExecutor || !string.IsNullOrWhiteSpace(Model.NomenclatureCaseLabel);
    var currentApprovalStep = Model.ApprovalRouteSteps.FirstOrDefault(x => x.IsCurrent) ?? Model.ApprovalRouteSteps.OrderBy(x => x.Order).FirstOrDefault();
    var approvalStepsCount = Model.ApprovalRouteSteps.Count;
    var completedApprovalSteps = Model.ApprovalRouteSteps.Count(x => string.Equals((x.Status ?? string.Empty).Trim(), "Approved", StringComparison.OrdinalIgnoreCase));
    var routeNeedsSetup = approvalStepsCount == 0;
    var hasAssignedExecutor = !string.IsNullOrWhiteSpace(Model.Assignment.AssignedUserName);
    var hasNomenclature = !string.IsNullOrWhiteSpace(Model.NomenclatureCaseLabel);
    var nextApprovalStep = currentApprovalStep is null
        ? null
        : Model.ApprovalRouteSteps
            .Where(x => x.Order > currentApprovalStep.Order)
            .OrderBy(x => x.Order)
            .FirstOrDefault();
    var currentApprovalActor = currentApprovalStep is null
        ? "Маршрут не подготовлен"
        : string.IsNullOrWhiteSpace(currentApprovalStep.ApproverDisplayName) || string.Equals(currentApprovalStep.ApproverDisplayName, "Не назначен", StringComparison.OrdinalIgnoreCase)
            ? currentApprovalStep.ApproverSpecializationLabel
            : $"{currentApprovalStep.ApproverSpecializationLabel} · {currentApprovalStep.ApproverDisplayName}";
    var routeProgressText = approvalStepsCount == 0
        ? "Маршрут пока не подготовлен"
        : completedApprovalSteps >= approvalStepsCount
            ? "Все шаги согласования завершены"
            : currentApprovalStep is null
                ? $"Подготовлено шагов: {approvalStepsCount}"
                : $"Шаг {currentApprovalStep.Order} из {approvalStepsCount}";
    var currentStageTitle = statusText switch
    {
        "Draft" => "Черновик",
        "OnApproval" => "Согласование",
        "Approved" => "Ожидает начала работы",
        "InWork" => "Исполнение",
        "Completed" => "Готов к архивированию",
        "Archived" => "Архив",
        _ => "Текущий этап"
    };
    var currentStageDescription = statusText switch
    {
        "Draft" => Model.CanEditDocument
            ? "Заполните карточку, проверьте шаблон и подготовьте маршрут согласования."
            : "Документ находится в черновике и ещё не отправлен в процесс.",
        "OnApproval" => $"Документ ожидает решение согласующего. Текущий шаг: {(currentApprovalStep is null ? "не подготовлен" : $"#{currentApprovalStep.Order} — {currentApprovalStep.Title}")}.",
        "Approved" => string.IsNullOrWhiteSpace(Model.Assignment.AssignedUserName)
            ? "Документ утверждён. Следующий шаг — назначить исполнителя."
            : $"Документ утверждён и ожидает начала работы исполнителем: {Model.Assignment.AssignedUserName}.",
        "InWork" => "Исполнитель работает с документом и должен зафиксировать результат исполнения.",
        "Completed" => "Исполнение завершено. Проверьте результат и подготовьте документ к архивированию.",
        "Archived" => "Документ завершил жизненный цикл и находится в архиве.",
        _ => "Следующее действие зависит от текущего статуса документа."
    };
    var currentStageAccent = statusText switch
    {
        "Draft" => "bg-slate-100 text-slate-700",
        "OnApproval" => "bg-amber-100 text-amber-800",
        "Approved" => "bg-blue-100 text-blue-800",
        "InWork" => "bg-violet-100 text-violet-800",
        "Completed" => "bg-emerald-100 text-emerald-800",
        "Archived" => "bg-slate-200 text-slate-700",
        _ => "bg-slate-100 text-slate-700"
    };
    var currentActionHint = statusText switch
    {
        "Draft" => Model.CanEditDocument ? "Сохраните карточку и подготовьте маршрут согласования." : "Ожидайте отправки документа в процесс.",
        "OnApproval" => Model.CanApprove ? "Проверьте документ и примите решение по согласованию." : "Документ ожидает решение согласующего.",
        "Approved" => Model.CanStartWork ? "Документ можно принять в работу." : "Ожидается назначение исполнителя или начало работы.",
        "InWork" => Model.CanSaveExecutionProgress ? "Зафиксируйте комментарий, результат и при необходимости приложите итоговый файл." : "Исполнитель ведет работу по документу.",
        "Completed" => canAssignExecutor ? "Проверьте результат и подготовьте документ к архивированию." : "Работа завершена, результат доступен для просмотра.",
        "Archived" => "Документ завершен и доступен только для просмотра.",
        _ => "Следующее действие зависит от этапа документа."
    };
    Func<string?, string> routeStatusLabel = status => (status ?? string.Empty).Trim() switch
    {
        "Template" => "Шаблон",
        "Pending" => "Ожидает",
        "Approved" => "Согласовано",
        "Reworked" => "Возврат",
        _ => string.IsNullOrWhiteSpace(status) ? "Не подготовлен" : status!
    };
    Func<string?, string> routeStatusAccent = status => (status ?? string.Empty).Trim() switch
    {
        "Template" => "bg-amber-100 text-amber-800 ring-amber-200",
        "Pending" => "bg-slate-100 text-slate-700 ring-slate-200",
        "Approved" => "bg-emerald-100 text-emerald-800 ring-emerald-200",
        "Reworked" => "bg-rose-100 text-rose-800 ring-rose-200",
        _ => "bg-slate-100 text-slate-700 ring-slate-200"
    };
}
<!DOCTYPE html>
<html class="light" lang="ru">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Редактирование документа - DocManager</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>body { font-family: "Inter", sans-serif; }</style>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen flex flex-col">
    <header class="sticky top-0 z-10 bg-white border-b border-slate-200">
        <div class="h-16 px-6 flex items-center justify-between">
            <div class="flex items-center gap-2 text-slate-900">
                <span class="material-symbols-outlined text-slate-700">description</span>
                <span class="font-bold">DocManager</span>
            </div>
            <div class="flex items-center gap-3">
                <a href="@Url.Action("Index", "Home")" class="px-4 py-2 rounded-lg text-sm font-medium text-slate-600 hover:text-slate-900">Назад к доске</a>
                @if (!isEmployeeRole)
                {
                    <a href="/Documents/@Model.Id/print-form" target="_blank" class="px-4 py-2 rounded-lg text-sm font-medium text-slate-600 ring-1 ring-slate-200 hover:text-slate-900 hover:bg-slate-50">Печатная форма</a>
                }
                @if (Model.CanEditDocument)
                {
                    <button type="submit" form="editDocumentForm" class="px-4 py-2 rounded-lg bg-slate-800 text-white text-sm font-medium hover:bg-slate-900">Сохранить</button>
                }
                @if (Model.CanAdvanceWorkflow)
                {
                    <form method="post" action="/Documents/@Model.Id/next-stage" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 flex items-center gap-2">
                            <span class="material-symbols-outlined text-[18px]">send</span>
                            Отправить на следующий этап
                        </button>
                    </form>
                }
            </div>
        </div>
    </header>

    <main class="flex-1 px-6 py-8 flex justify-center">
        <div class="w-full max-w-6xl space-y-6">
            <div>
                <div class="text-sm text-slate-500">Документ #@Model.Id</div>
                <h1 class="text-2xl font-bold">Редактирование документа</h1>
                <div class="mt-1 text-sm text-slate-600">Текущий статус: <span class="font-semibold">@Model.Status</span></div>
            </div>

            @if (TempData["SuccessMessage"] is string ok && !string.IsNullOrWhiteSpace(ok))
            {
                <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">@ok</div>
            }

            @if (TempData["ErrorMessage"] is string err && !string.IsNullOrWhiteSpace(err))
            {
                <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">@err</div>
            }

            <section class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
                <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
                    <div class="space-y-3">
                        <div class="flex items-center gap-3">
                            <span class="rounded-full px-3 py-1 text-xs font-semibold @currentStageAccent">@currentStageTitle</span>
                            <span class="text-xs uppercase tracking-widest text-slate-500">Документ в процессе</span>
                        </div>
                        <div class="max-w-3xl text-sm leading-6 text-slate-700">@currentStageDescription</div>
                    </div>
                    <div class="grid min-w-[280px] grid-cols-1 gap-3 sm:grid-cols-2">
                        <div class="rounded-xl bg-slate-50 px-4 py-3">
                            <div class="text-[11px] font-bold uppercase tracking-wider text-slate-500">Текущий согласующий</div>
                            <div class="mt-1 text-sm font-medium text-slate-900">@currentApprovalActor</div>
                        </div>
                        <div class="rounded-xl bg-slate-50 px-4 py-3">
                            <div class="text-[11px] font-bold uppercase tracking-wider text-slate-500">Режим экрана</div>
                            <div class="mt-1 text-sm font-medium text-slate-900">@(Model.CanEditDocument ? "Управление документом" : "Просмотр и действия исполнителя")</div>
                        </div>
                    </div>
                </div>
            </section>

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
                <div class="lg:col-span-7 xl:col-span-8 space-y-6">
                    @if (showAiPanel)
                    {
                        <section class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
                            <div class="flex items-center justify-between gap-4 mb-4">
                                <div class="flex items-center gap-2">
                                    <span class="material-symbols-outlined text-blue-600">smart_toy</span>
                                    <h2 class="text-sm font-bold uppercase tracking-widest text-slate-600">ИИ-рекомендации</h2>
                                </div>
                                <div class="text-xs text-slate-500">Рекомендации для менеджера при заполнении карточки</div>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                                @foreach (var s in Model.AiSuggestions)
                                {
                                    var isHigh = s.Confidence >= 85;
                                    var needsReview = s.Confidence >= 60 && s.Confidence < 85;
                                    <div class="rounded-xl border @(isHigh ? "border-emerald-200 bg-emerald-50/60" : needsReview ? "border-amber-200 bg-amber-50/70" : "border-slate-200 bg-slate-50") px-4 py-3">
                                        <div class="flex items-start justify-between gap-3">
                                            <div>
                                                <div class="text-[10px] uppercase tracking-widest font-bold text-slate-500">@s.Label</div>
                                                <div class="mt-1 text-sm font-medium text-slate-900 break-words">@s.SuggestedValue</div>
                                                <div class="mt-2 text-xs text-slate-600">
                                                    Уверенность: <span class="font-semibold">@s.Confidence%</span>
                                                    <span class="ml-2 @(isHigh ? "text-emerald-700" : needsReview ? "text-amber-700" : "text-slate-500")">
                                                        @(isHigh ? "автоприменение допустимо" : needsReview ? "нужна проверка" : "лучше проверить вручную")
                                                    </span>
                                                </div>
                                            </div>
                                            <button type="button" class="shrink-0 px-3 py-1.5 rounded-lg text-xs font-semibold @(isHigh ? "bg-emerald-600 text-white hover:bg-emerald-700" : needsReview ? "bg-amber-600 text-white hover:bg-amber-700" : "bg-slate-700 text-white hover:bg-slate-800")" data-ai-apply data-field="@s.FieldKey" data-value="@s.SuggestedValue">Применить</button>
                                        </div>
                                    </div>
                                }
                            </div>
                        </section>
                    }

                    @if (Model.CanEditDocument)
                    {
                        <form id="editDocumentForm" method="post" asp-action="Edit" class="space-y-6">
                            @Html.AntiForgeryToken()
                            <input type="hidden" asp-for="Id" />

                            <div asp-validation-summary="ModelOnly" class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800"></div>

                            <section class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm space-y-5">
                                <div class="flex items-start justify-between gap-4">
                                    <div>
                                        <h2 class="text-sm font-bold uppercase tracking-widest text-slate-600">Основные реквизиты</h2>
                                        <p class="mt-1 text-sm text-slate-500">Здесь менеджер или администратор заполняет и корректирует карточку документа.</p>
                                    </div>
                                    <span class="rounded-lg bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-700">Режим управления</span>
                                </div>

                                <fieldset class="space-y-5">
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                        <div class="md:col-span-2">
                                            <label asp-for="Title" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Название</label>
                                            <input asp-for="Title" id="field-title" class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5 focus:ring-2 focus:ring-blue-600 focus:border-blue-600" />
                                            <span asp-validation-for="Title" class="text-xs text-red-600"></span>
                                        </div>

                                        <div>
                                            <label asp-for="Type" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Тип</label>
                                            <select asp-for="Type" id="field-type" asp-items="Html.GetEnumSelectList<DocumentType>()" class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5 focus:ring-2 focus:ring-blue-600 focus:border-blue-600">
                                                <option value="">Выберите тип</option>
                                            </select>
                                            <span asp-validation-for="Type" class="text-xs text-red-600"></span>
                                        </div>

                                        <div>
                                            <label asp-for="DueDate" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Срок исполнения</label>
                                            <input asp-for="DueDate" id="field-duedate" class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5 focus:ring-2 focus:ring-blue-600 focus:border-blue-600" />
                                            <span asp-validation-for="DueDate" class="text-xs text-red-600"></span>
                                        </div>
                                    </div>

                                    <div>
                                        <label asp-for="Description" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Описание</label>
                                        <textarea asp-for="Description" id="field-description" rows="4" class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5 focus:ring-2 focus:ring-blue-600 focus:border-blue-600"></textarea>
                                        <span asp-validation-for="Description" class="text-xs text-red-600"></span>
                                    </div>

                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                        <div>
                                            <label asp-for="Priority" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Приоритет</label>
                                            <select asp-for="Priority" id="field-priority" class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5 focus:ring-2 focus:ring-blue-600 focus:border-blue-600">
                                                <option value="">Не выбран</option>
                                                <option value="1">Низкий</option>
                                                <option value="2">Средний</option>
                                                <option value="3">Высокий</option>
                                            </select>
                                            <span asp-validation-for="Priority" class="text-xs text-red-600"></span>
                                        </div>

                                        <div>
                                            <label asp-for="Tags" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Теги</label>
                                            <input asp-for="Tags" id="field-tags" class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5 focus:ring-2 focus:ring-blue-600 focus:border-blue-600" placeholder="Например: финансы, договор, согласование" />
                                            <span asp-validation-for="Tags" class="text-xs text-red-600"></span>
                                        </div>
                                    </div>
                                </fieldset>
                            </section>

                            @if (Model.TemplateFields.Count > 0)
                            {
                                <section class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm">
                                    <div class="flex items-start justify-between gap-4">
                                        <div>
                                            <h2 class="text-sm font-bold uppercase tracking-widest text-slate-600">Данные шаблона</h2>
                                            <p class="mt-1 text-sm text-slate-500">@(string.IsNullOrWhiteSpace(Model.TemplateName) ? "Поля документа" : Model.TemplateName)</p>
                                        </div>
                                        <span class="rounded-lg bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">Только просмотр</span>
                                    </div>

                                    <div class="mt-5 grid grid-cols-1 md:grid-cols-2 gap-4">
                                        @foreach (var field in Model.TemplateFields)
                                        {
                                            <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                                                <div class="text-xs font-bold uppercase tracking-wider text-slate-500">
                                                    @field.Label
                                                    @if (field.Required)
                                                    {
                                                        <span class="text-red-500">*</span>
                                                    }
                                                </div>
                                                <div class="mt-1 text-sm font-medium text-slate-900 whitespace-pre-wrap break-words">@field.Value</div>
                                            </div>
                                        }
                                    </div>
                                </section>
                            }
                        </form>
                    }
                    else
                    {
                        <section class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm space-y-5">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <h2 class="text-sm font-bold uppercase tracking-widest text-slate-600">Кратко о документе</h2>
                                    <p class="mt-1 text-sm text-slate-500">Показываем только те сведения, которые нужны для согласования и исполнения.</p>
                                </div>
                                <span class="rounded-lg bg-blue-50 px-3 py-1 text-xs font-semibold text-blue-700">Рабочий режим</span>
                            </div>

                            <div class="grid grid-cols-1 gap-4 md:grid-cols-2">
                                <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                                    <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Название</div>
                                    <div class="mt-1 text-sm font-medium text-slate-900">@Model.Title</div>
                                </div>
                                <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                                    <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Тип документа</div>
                                    <div class="mt-1 text-sm font-medium text-slate-900">@Model.Type</div>
                                </div>
                                <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                                    <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Срок исполнения</div>
                                    <div class="mt-1 text-sm font-medium text-slate-900">@(Model.DueDate.HasValue ? Model.DueDate.Value.ToString("dd.MM.yyyy") : "Не указан")</div>
                                </div>
                                <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                                    <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Приоритет</div>
                                    <div class="mt-1 text-sm font-medium text-slate-900">@(Model.Priority switch { 1 => "Низкий", 2 => "Средний", 3 => "Высокий", _ => "Не выбран" })</div>
                                </div>
                            </div>

                            <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                                <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Описание</div>
                                <div class="mt-1 whitespace-pre-wrap text-sm leading-6 text-slate-700">@Model.Description</div>
                            </div>

                            @if (Model.TemplateFields.Count > 0)
                            {
                                <section class="space-y-4">
                                    <div>
                                        <h2 class="text-sm font-bold uppercase tracking-widest text-slate-600">Данные шаблона</h2>
                                        <p class="mt-1 text-sm text-slate-500">@(string.IsNullOrWhiteSpace(Model.TemplateName) ? "Поля документа" : Model.TemplateName)</p>
                                    </div>
                                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                                        @foreach (var field in Model.TemplateFields)
                                        {
                                            <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                                                <div class="text-xs font-bold uppercase tracking-wider text-slate-500">@field.Label</div>
                                                <div class="mt-1 text-sm font-medium text-slate-900 whitespace-pre-wrap break-words">@field.Value</div>
                                            </div>
                                        }
                                    </div>
                                </section>
                            }
                        </section>
                    }
                </div>

                <div class="space-y-6 lg:col-span-5 xl:col-span-4 xl:sticky xl:top-[88px] xl:max-h-[calc(100vh-112px)] xl:overflow-y-auto xl:pr-1">
                    <section class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                        <div class="px-4 py-3 border-b border-slate-200 bg-slate-50">
                            <div class="text-sm font-semibold text-slate-700">Что происходит сейчас</div>
                        </div>
                        <div class="p-4 space-y-4">
                            <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3">
                                <div class="flex items-center justify-between gap-3">
                                    <div>
                                        <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Текущий этап</div>
                                        <div class="mt-1 text-sm font-semibold text-slate-900">@currentStageTitle</div>
                                    </div>
                                    <span class="rounded-full px-3 py-1 text-xs font-semibold @currentStageAccent">@Model.Status</span>
                                </div>
                                <div class="mt-3 text-sm leading-6 text-slate-700">@currentActionHint</div>
                            </div>

                            <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                                <div class="rounded-xl bg-slate-50 px-4 py-3">
                                    <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Маршрут</div>
                                    <div class="mt-1 text-sm font-medium text-slate-900">@routeProgressText</div>
                                    <div class="mt-2 text-xs text-slate-500">@(routeNeedsSetup ? "Подготовьте маршрут перед отправкой на согласование." : $"Согласовано шагов: {completedApprovalSteps} из {approvalStepsCount}")</div>
                                </div>
                                <div class="rounded-xl bg-slate-50 px-4 py-3">
                                    <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Следующий участник</div>
                                    <div class="mt-1 text-sm font-medium text-slate-900">
                                        @if (routeNeedsSetup && string.Equals(statusText, "Draft", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <span>Сначала подготовьте маршрут</span>
                                        }
                                        else if (string.Equals(statusText, "OnApproval", StringComparison.OrdinalIgnoreCase))
                                        {
                                            @currentApprovalActor
                                        }
                                        else if (nextApprovalStep is not null)
                                        {
                                            @(string.IsNullOrWhiteSpace(nextApprovalStep.ApproverDisplayName) || string.Equals(nextApprovalStep.ApproverDisplayName, "Не назначен", StringComparison.OrdinalIgnoreCase)
                                                ? nextApprovalStep.ApproverSpecializationLabel
                                                : $"{nextApprovalStep.ApproverSpecializationLabel} · {nextApprovalStep.ApproverDisplayName}")
                                        }
                                        else if (!string.IsNullOrWhiteSpace(Model.Assignment.AssignedUserName))
                                        {
                                            @Model.Assignment.AssignedUserName
                                        }
                                        else
                                        {
                                            <span>Будет определен на следующем этапе</span>
                                        }
                                    </div>
                                </div>
                            </div>
                        </div>
                    </section>

                    @if (hasUserActions)
                    {
                        <section class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                            <div class="px-4 py-3 border-b border-slate-200 bg-slate-50">
                                <div class="text-sm font-semibold text-slate-700">Действия по документу</div>
                            </div>
                            <div class="p-4 space-y-3">
                                <div class="rounded-xl border border-blue-200 bg-blue-50 px-4 py-3 text-sm leading-6 text-blue-900">
                                    @currentActionHint
                                </div>

                                @if (Model.CanApprove)
                                {
                                    <form method="post" action="/Documents/@Model.Id/review">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Decision" value="approve" />
                                        <button type="submit" class="w-full rounded-lg bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-emerald-700">
                                            Утвердить документ
                                        </button>
                                    </form>
                                }

                                @if (Model.CanRework)
                                {
                                    <form method="post" action="/Documents/@Model.Id/review" class="space-y-3">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="Decision" value="rework" />
                                        <label class="block text-xs uppercase tracking-wider font-bold text-slate-500">Комментарий для доработки</label>
                                        <textarea name="Comment" rows="3" class="w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5" placeholder="Укажите, что нужно исправить"></textarea>
                                        <button type="submit" class="w-full rounded-lg bg-amber-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-amber-700">
                                            Вернуть на доработку
                                        </button>
                                    </form>
                                }

                                @if (Model.CanStartWork)
                                {
                                    <form method="post" action="/Documents/@Model.Id/start-work">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnToEdit" value="true" />
                                        <button type="submit" class="w-full rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-700">
                                            Начать работу
                                        </button>
                                    </form>
                                }

                                @if (Model.CanComplete)
                                {
                                    <form method="post" action="/Documents/@Model.Id/complete-work">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnToEdit" value="true" />
                                        <button type="submit" class="w-full rounded-lg bg-emerald-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-emerald-700">
                                            Завершить исполнение
                                        </button>
                                    </form>
                                }
                            </div>
                        </section>
                    }

                    @if (hasExecutionBlock)
                    {
                        <section class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                            <div class="px-4 py-3 border-b border-slate-200 bg-slate-50">
                                <div class="text-sm font-semibold text-slate-700">Исполнение документа</div>
                            </div>
                            <div class="p-4 space-y-4">
                                <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                                    <div class="rounded-xl bg-slate-50 px-4 py-3">
                                        <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Дата начала</div>
                                        <div class="mt-1 font-medium text-slate-900">@(Model.ExecutionStartedAt.HasValue ? Model.ExecutionStartedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "Еще не начато")</div>
                                    </div>
                                    <div class="rounded-xl bg-slate-50 px-4 py-3">
                                        <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Дата завершения</div>
                                        <div class="mt-1 font-medium text-slate-900">@(Model.ExecutionCompletedAt.HasValue ? Model.ExecutionCompletedAt.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm") : "Еще не завершено")</div>
                                    </div>
                                </div>

                                @if (Model.ExecutionHintItems.Count > 0)
                                {
                                    <div class="rounded-xl border border-blue-200 bg-blue-50 px-4 py-3">
                                        <div class="text-xs font-bold uppercase tracking-wider text-blue-700">@Model.ExecutionHintTitle</div>
                                        <ul class="mt-2 list-disc space-y-1 pl-5 text-sm text-blue-900">
                                            @foreach (var item in Model.ExecutionHintItems)
                                            {
                                                <li>@item</li>
                                            }
                                        </ul>
                                    </div>
                                }

                                @if (isEmployeeRole)
                                {
                                    <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm leading-6 text-slate-600">
                                        Здесь нужен только рабочий результат: комментарий, итог исполнения и при необходимости сформированный системой файл.
                                    </div>
                                }

                                @if (Model.CanSaveExecutionProgress)
                                {
                                    <form method="post" action="/Documents/@Model.Id/execution" class="space-y-4">
                                        @Html.AntiForgeryToken()
                                        <div>
                                            <label asp-for="ExecutionComment" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Комментарий исполнителя</label>
                                            <textarea asp-for="ExecutionComment" rows="4" class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5" placeholder="Кратко опишите, что уже сделано по документу"></textarea>
                                        </div>
                                        <div>
                                            <label asp-for="ExecutionResult" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Результат исполнения</label>
                                            <select asp-for="ExecutionResult" class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5">
                                                <option value="">Выберите результат</option>
                                                @foreach (var option in Model.ExecutionResultOptions)
                                                {
                                                    <option value="@option">@option</option>
                                                }
                                            </select>
                                        </div>
                                        <button type="submit" class="w-full rounded-lg bg-slate-800 px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-900">
                                            Сохранить ход исполнения
                                        </button>
                                    </form>

                                    @if (!isEmployeeRole)
                                    {
                                        <form method="post" action="/Documents/@Model.Id/execution-file" enctype="multipart/form-data" class="space-y-4 rounded-xl border border-slate-200 bg-slate-50 px-4 py-4">
                                            @Html.AntiForgeryToken()
                                            <div>
                                                <label for="executionFile" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Итоговый файл</label>
                                                <input id="executionFile" name="executionFile" type="file" accept=".pdf,.docx,.xlsx,.png,.jpg,.jpeg" class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5" />
                                                <div class="mt-1 text-xs text-slate-500">Поддерживаются PDF, DOCX, XLSX, PNG и JPEG до 25MB.</div>
                                            </div>
                                            <button type="submit" class="w-full rounded-lg bg-white px-4 py-2.5 text-sm font-semibold text-slate-800 ring-1 ring-slate-300 hover:bg-slate-100">
                                                Загрузить итоговый файл
                                            </button>
                                        </form>
                                    }

                                    <form method="post" action="/Documents/@Model.Id/execution-print-file" class="space-y-3 rounded-xl border border-blue-200 bg-blue-50 px-4 py-4">
                                        @Html.AntiForgeryToken()
                                        <div class="text-sm text-blue-900">
                                            Система сформирует официальный итоговый файл исполнения из карточки документа и сохранит его автоматически.
                                        </div>
                                        <button type="submit" class="w-full rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-700">
                                            Сформировать итоговый файл
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600">
                                        Блок исполнения доступен для просмотра. Изменять его может только назначенный исполнитель во время работы над документом.
                                    </div>
                                }

                                <div class="rounded-xl bg-slate-50 px-4 py-3">
                                    <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Текущий результат</div>
                                    <div class="mt-1 font-medium text-slate-900">@(string.IsNullOrWhiteSpace(Model.ExecutionResult) ? "Пока не выбран" : Model.ExecutionResult)</div>
                                </div>

                                <div class="rounded-xl bg-slate-50 px-4 py-3">
                                    <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Комментарий исполнителя</div>
                                    <div class="mt-1 text-sm leading-6 text-slate-700">@(string.IsNullOrWhiteSpace(Model.ExecutionComment) ? "Комментарий пока не добавлен." : Model.ExecutionComment)</div>
                                </div>

                                @if (showDedicatedExecutionFileBlock)
                                {
                                    <div class="rounded-xl border border-blue-200 bg-blue-50 px-4 py-3">
                                        <div class="text-xs font-bold uppercase tracking-wider text-blue-700">Итоговый файл</div>
                                        <div class="mt-2 flex items-center justify-between gap-3">
                                            <div class="text-sm text-slate-700">@(string.IsNullOrWhiteSpace(Model.ExecutionFileName) ? "Файл исполнения" : Model.ExecutionFileName)</div>
                                            <a href="@Model.ExecutionFileUrl" target="_blank" class="rounded-lg border border-blue-200 bg-white px-3 py-2 text-sm font-medium text-blue-700 hover:bg-blue-100">Открыть</a>
                                        </div>
                                        <div class="mt-2 text-xs text-blue-700 break-all">Путь в БД: @Model.ExecutionFileUrl</div>
                                        @if (string.Equals(Model.ExecutionFileKind, "image", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <div class="mt-3 rounded-lg border border-blue-100 bg-white p-3">
                                                <img class="max-h-72 max-w-full object-contain rounded" src="@Model.ExecutionFileUrl" alt="Превью итогового файла" />
                                            </div>
                                        }
                                        else if (string.Equals(Model.ExecutionFileKind, "pdf", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <div class="mt-3 rounded-lg border border-blue-100 bg-white p-2">
                                                <iframe class="h-72 w-full rounded" src="@Model.ExecutionFileUrl"></iframe>
                                            </div>
                                        }
                                        else if (string.Equals(Model.ExecutionFileKind, "html", StringComparison.OrdinalIgnoreCase))
                                        {
                                            <div class="mt-3 rounded-lg border border-blue-100 bg-white p-2">
                                                <iframe class="h-72 w-full rounded" src="@Model.ExecutionFileUrl"></iframe>
                                            </div>
                                        }
                                    </div>
                                }
                                else if (hasExecutionFile)
                                {
                                    <div class="rounded-xl border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-900">
                                        Итоговый файл уже доступен в блоке просмотра ниже.
                                    </div>
                                }
                            </div>
                        </section>
                    }

                    <section class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                        <div class="px-4 py-3 border-b border-slate-200 bg-slate-50">
                            <div class="text-sm font-semibold text-slate-700">Маршрут согласования</div>
                        </div>
                        <div class="p-4 space-y-4">
                            <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                                <div class="rounded-xl bg-slate-50 px-4 py-3">
                                    <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Текущий шаблон</div>
                                    <div class="mt-1 font-medium text-slate-900">@(string.IsNullOrWhiteSpace(Model.RouteTemplateName) ? "Не выбран" : Model.RouteTemplateName)</div>
                                </div>
                                <div class="rounded-xl bg-slate-50 px-4 py-3">
                                    <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Прогресс маршрута</div>
                                    <div class="mt-1 font-medium text-slate-900">@routeProgressText</div>
                                    <div class="mt-2 text-xs text-slate-500">@(approvalStepsCount == 0 ? "Шаги ещё не подготовлены." : $"Согласовано шагов: {completedApprovalSteps} из {approvalStepsCount}")</div>
                                </div>
                            </div>

                            @if (routeNeedsSetup)
                            {
                                <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm leading-6 text-amber-900">
                                    Маршрут ещё не подготовлен. Выберите шаблон и сформируйте шаги, чтобы документ можно было отправить на согласование.
                                </div>
                            }

                            @if (Model.CanConfigureApprovalRoute)
                            {
                                <form method="post" action="/Documents/@Model.Id/approval-route" class="space-y-3">
                                    @Html.AntiForgeryToken()
                                    <label class="block text-xs uppercase tracking-wider font-bold text-slate-500">Шаблон маршрута</label>
                                    <select name="routeTemplateId" class="w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5">
                                        <option value="">Выберите шаблон</option>
                                        @foreach (var routeTemplate in Model.RouteTemplateOptions)
                                        {
                                            <option value="@routeTemplate.Id" selected="@(Model.RouteTemplateId == routeTemplate.Id)">
                                                @routeTemplate.Name
                                            </option>
                                        }
                                    </select>
                                    <div class="text-xs text-slate-500">Подготовьте маршрут перед отправкой документа на согласование. После отправки шаги блокируются.</div>
                                    <button type="submit" class="w-full rounded-lg bg-slate-800 px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-900">Подготовить маршрут</button>
                                </form>
                            }

                            <div class="space-y-3">
                                @if (Model.ApprovalRouteSteps.Count == 0)
                                {
                                    <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-4 py-5 text-sm text-slate-600">
                                        После подготовки маршрута здесь появятся шаги согласования, роли и текущий ответственный.
                                    </div>
                                }
                                else
                                {
                                    @foreach (var step in Model.ApprovalRouteSteps.OrderBy(x => x.Order))
                                    {
                                        var rawStepStatus = (step.Status ?? string.Empty).Trim();
                                        var isApprovedStep = string.Equals(rawStepStatus, "Approved", StringComparison.OrdinalIgnoreCase);
                                        var isPendingStep = string.Equals(rawStepStatus, "Pending", StringComparison.OrdinalIgnoreCase);
                                        var isReworkedStep = string.Equals(rawStepStatus, "Reworked", StringComparison.OrdinalIgnoreCase);
                                        var stepBorder = step.IsCurrent
                                            ? "border-blue-300 bg-blue-50/60"
                                            : isApprovedStep
                                                ? "border-emerald-200 bg-emerald-50/70"
                                                : isReworkedStep
                                                    ? "border-rose-200 bg-rose-50/70"
                                                    : "border-slate-200 bg-white";
                                        var markerAccent = step.IsCurrent
                                            ? "bg-blue-600 text-white ring-blue-100"
                                            : isApprovedStep
                                                ? "bg-emerald-600 text-white ring-emerald-100"
                                                : isReworkedStep
                                                    ? "bg-rose-600 text-white ring-rose-100"
                                                    : isPendingStep
                                                        ? "bg-slate-300 text-slate-700 ring-slate-100"
                                                        : "bg-slate-200 text-slate-600 ring-slate-100";
                                        var statusBadge = step.IsCurrent ? "Текущий шаг" : routeStatusLabel(step.Status);
                                        var statusAccent = step.IsCurrent ? "bg-blue-100 text-blue-800 ring-blue-200" : routeStatusAccent(step.Status);
                                        <div class="rounded-xl border p-4 @stepBorder">
                                            <div class="flex items-start gap-4">
                                                <div class="flex flex-col items-center">
                                                    <div class="flex h-10 w-10 items-center justify-center rounded-full text-sm font-bold ring-4 @markerAccent">@step.Order</div>
                                                    @if (step.Order < approvalStepsCount)
                                                    {
                                                        <div class="mt-2 h-10 w-px bg-slate-200"></div>
                                                    }
                                                </div>
                                                <div class="min-w-0 flex-1 space-y-3">
                                                    <div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
                                                        <div class="min-w-0">
                                                            <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Шаг @step.Order</div>
                                                            <div class="mt-1 text-base font-semibold text-slate-900">@step.Title</div>
                                                            <div class="mt-2 text-sm leading-6 text-slate-600">
                                                                @step.ApproverRole · @step.ApproverSpecializationLabel
                                                                @if (!string.IsNullOrWhiteSpace(step.ApproverDisplayName) && !string.Equals(step.ApproverDisplayName, "Не назначен", StringComparison.OrdinalIgnoreCase))
                                                                {
                                                                    <span> · @step.ApproverDisplayName</span>
                                                                }
                                                            </div>
                                                        </div>
                                                        <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold ring-1 @statusAccent">@statusBadge</span>
                                                    </div>

                                                    @if (step.IsCurrent)
                                                    {
                                                        <div class="rounded-xl border border-blue-200 bg-white/80 px-4 py-3 text-sm text-blue-900">
                                                            Сейчас документ ожидает решение именно на этом шаге.
                                                        </div>
                                                    }

                                                    @if (Model.CanConfigureApprovalRoute && step.DocumentApprovalStepId.HasValue)
                                                    {
                                                        <form method="post" action="/Documents/@Model.Id/approval-route/step" class="rounded-xl border border-slate-200 bg-white/80 p-3">
                                                            @Html.AntiForgeryToken()
                                                            <input type="hidden" name="documentApprovalStepId" value="@step.DocumentApprovalStepId" />
                                                            <div class="space-y-2">
                                                                <label class="block text-xs font-bold uppercase tracking-wider text-slate-500">Переопределить согласующего</label>
                                                                <select name="approverUserId" class="w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-3 py-2">
                                                                    <option value="">Автоназначение по бизнес-роли</option>
                                                                    @foreach (var approver in Model.RouteApproverOptions.Where(option =>
                                                                    string.IsNullOrWhiteSpace(step.ApproverSpecialization) ||
                                                                    string.Equals(option.ApprovalSpecialization, step.ApproverSpecialization, StringComparison.OrdinalIgnoreCase)))
                                                                    {
                                                                        <option value="@approver.UserId" selected="@(step.ApproverUserId == approver.UserId)">@approver.DisplayName (@approver.RoleName, @approver.ApprovalSpecializationLabel)</option>
                                                                    }
                                                                </select>
                                                                <button type="submit" class="w-full rounded-lg bg-blue-600 px-3 py-2 text-sm font-semibold text-white hover:bg-blue-700">Сохранить согласующего</button>
                                                            </div>
                                                        </form>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </section>

                    @if (isEmployeeRole)
                    {
                        <section class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                            <div class="px-4 py-3 border-b border-slate-200 bg-slate-50">
                                <div class="text-sm font-semibold text-slate-700">Служебная информация</div>
                            </div>
                            <div class="p-4 space-y-4">
                                <div class="grid grid-cols-1 gap-3 sm:grid-cols-2">
                                    <div class="rounded-xl bg-slate-50 px-4 py-3">
                                        <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Исполнитель</div>
                                        <div class="mt-1 text-sm font-medium text-slate-900">@(hasAssignedExecutor ? Model.Assignment.AssignedUserName : "Не назначен")</div>
                                    </div>
                                    <div class="rounded-xl bg-slate-50 px-4 py-3">
                                        <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Номенклатура</div>
                                        <div class="mt-1 text-sm font-medium text-slate-900">@(hasNomenclature ? Model.NomenclatureCaseLabel : "Не привязано")</div>
                                    </div>
                                </div>
                            </div>
                        </section>
                    }
                    else
                    {
                        @if (showAssignmentSection)
                        {
                            <section class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                                <div class="px-4 py-3 border-b border-slate-200 bg-slate-50">
                                    <div class="text-sm font-semibold text-slate-700">Назначение исполнителя</div>
                                </div>
                                <div class="p-4 space-y-4">
                                    <div class="rounded-xl bg-slate-50 px-4 py-3">
                                        <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Текущий исполнитель</div>
                                        <div class="mt-1 font-medium text-slate-900">@(hasAssignedExecutor ? Model.Assignment.AssignedUserName : "Не назначен")</div>
                                        <div class="mt-2 text-xs text-slate-500">@(hasAssignedExecutor ? "Исполнитель увидит документ в своих задачах и сможет начать работу." : "После утверждения выберите сотрудника, который будет выполнять документ.")</div>
                                    </div>

                                    @if (canAssignExecutor && Model.Assignment.CanAssign)
                                    {
                                        <form method="post" action="/Documents/@Model.Id/assign" class="space-y-3">
                                            @Html.AntiForgeryToken()
                                            <label class="block text-xs uppercase tracking-wider font-bold text-slate-500">Назначить исполнителя</label>
                                            <select name="assignedUserId" class="w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5">
                                                <option value="">Выберите исполнителя</option>
                                                @foreach (var executor in Model.Assignment.Executors)
                                                {
                                                    <option value="@executor.UserId" selected="@(Model.Assignment.AssignedUserId == executor.UserId)">@executor.DisplayName (@executor.Email)</option>
                                                }
                                            </select>
                                            <button type="submit" class="w-full rounded-lg bg-blue-600 px-4 py-2.5 text-sm font-semibold text-white hover:bg-blue-700">Сохранить назначение</button>
                                        </form>
                                    }
                                    else if (canAssignExecutor)
                                    {
                                        <div class="rounded-xl border border-slate-200 bg-slate-50 px-4 py-3 text-sm text-slate-600">
                                            Назначение станет доступно после завершения согласования и перевода документа в утверждённый статус.
                                        </div>
                                    }
                                </div>
                            </section>
                        }

                        @if (showNomenclatureSection)
                        {
                            <section class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                                <div class="px-4 py-3 border-b border-slate-200 bg-slate-50">
                                    <div class="text-sm font-semibold text-slate-700">Номенклатура дела</div>
                                </div>
                                <div class="p-4 space-y-4">
                                    <div class="rounded-xl bg-slate-50 px-4 py-3">
                                        <div class="text-xs font-bold uppercase tracking-wider text-slate-500">Текущее дело</div>
                                        <div class="mt-1 font-medium text-slate-900">@(hasNomenclature ? Model.NomenclatureCaseLabel : "Не привязано")</div>
                                        <div class="mt-2 text-xs text-slate-500">@(hasNomenclature ? "Документ уже привязан к делу и сможет быть отправлен в архив." : "Без привязки к делу документ нельзя архивировать.")</div>
                                    </div>

                                    @if (canAssignExecutor)
                                    {
                                        <form method="post" action="/Documents/@Model.Id/nomenclature" class="space-y-3">
                                            @Html.AntiForgeryToken()
                                            <label class="block text-xs uppercase tracking-wider font-bold text-slate-500">Привязать к делу номенклатуры</label>
                                            <select name="nomenclatureCaseId" class="w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5">
                                                <option value="">Не выбрано</option>
                                                @foreach (var item in Model.NomenclatureCaseOptions)
                                                {
                                                    <option value="@item.Id" selected="@(Model.NomenclatureCaseId == item.Id)">@item.Label</option>
                                                }
                                            </select>
                                            <div class="text-xs text-slate-500">Перед архивированием документ должен быть привязан к делу номенклатуры.</div>
                                            <button type="submit" class="w-full rounded-lg bg-slate-800 px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-900">Сохранить номенклатуру</button>
                                        </form>
                                    }
                                </div>
                            </section>
                        }
                    }

                    <section class="bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                        <div class="px-4 py-3 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
                            <div>
                                <div class="text-sm font-semibold text-slate-700">@previewTitle</div>
                                @if (!hasSourceFile && hasExecutionFile)
                                {
                                    <div class="mt-1 text-xs text-slate-500">Исходный файл не прикреплен, поэтому показан файл результата исполнения.</div>
                                }
                            </div>
                            @if (!string.IsNullOrWhiteSpace(previewUrl))
                            {
                                <a class="text-xs text-slate-500 hover:text-blue-600" href="@previewUrl" target="_blank">Открыть</a>
                            }
                        </div>
                        <div class="bg-slate-100 p-3">
                            @if (string.IsNullOrWhiteSpace(previewUrl))
                            {
                                <div class="flex min-h-[220px] items-center justify-center px-6 text-center">
                                    <div class="max-w-sm space-y-3 text-sm text-slate-500">
                                        <div class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-white text-slate-400 shadow-sm">
                                            <span class="material-symbols-outlined">visibility_off</span>
                                        </div>
                                        <div class="font-medium text-slate-700">Пока нет файла для просмотра</div>
                                        <div>
                                            Документ создан по карточке без исходного вложения. Превью появится после загрузки исходного документа или итогового файла исполнения.
                                        </div>
                                    </div>
                                </div>
                            }
                            else if (string.Equals(previewKind, "image", StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="h-[520px] rounded-lg border border-slate-200 bg-white flex items-center justify-center p-3 overflow-auto">
                                    <img class="max-h-full max-w-full object-contain rounded" src="@previewUrl" alt="Превью документа" />
                                </div>
                            }
                            else if (string.Equals(previewKind, "pdf", StringComparison.OrdinalIgnoreCase))
                            {
                                <iframe class="w-full h-[520px] rounded-lg border border-slate-200 bg-white" src="@previewUrl"></iframe>
                            }
                            else if (string.Equals(previewKind, "html", StringComparison.OrdinalIgnoreCase))
                            {
                                <iframe class="w-full h-[520px] rounded-lg border border-slate-200 bg-white" src="@previewUrl"></iframe>
                            }
                            else
                            {
                                <div class="h-[520px] flex items-center justify-center text-sm text-slate-500 text-center px-4">Превью недоступно для этого типа файла. Нажмите «Открыть», чтобы скачать или просмотреть файл.</div>
                            }
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </main>

    <script>
        (function () {
            function setValue(selector, value) {
                const el = document.querySelector(selector);
                if (!el) return;
                el.value = value;
                el.dispatchEvent(new Event("input", { bubbles: true }));
                el.dispatchEvent(new Event("change", { bubbles: true }));
                el.focus();
            }

            document.querySelectorAll("[data-ai-apply]").forEach((btn) => {
                btn.addEventListener("click", () => {
                    const field = btn.getAttribute("data-field");
                    const value = btn.getAttribute("data-value") || "";

                    switch ((field || "").toLowerCase()) {
                        case "title": setValue("#field-title", value); break;
                        case "type": setValue("#field-type", value); break;
                        case "duedate": setValue("#field-duedate", value); break;
                        case "description": setValue("#field-description", value); break;
                        case "priority": setValue("#field-priority", value); break;
                        case "tags": setValue("#field-tags", value); break;
                    }
                });
            });
        })();
    </script>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>
