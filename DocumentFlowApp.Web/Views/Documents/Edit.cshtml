@model DocumentFlowApp.Web.Models.EditDocumentPageViewModel
@using DocumentFlowApp.Core.Enums
@{
    Layout = null;
}
<!DOCTYPE html>
<html class="light" lang="ru">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Редактирование документа - DocManager</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <style>body { font-family: "Inter", sans-serif; }</style>
</head>
<body class="bg-slate-50 text-slate-900 min-h-screen flex flex-col">
    <header class="sticky top-0 z-10 bg-white border-b border-slate-200">
        <div class="h-16 px-6 flex items-center justify-between">
            <div class="flex items-center gap-2 text-slate-900">
                <span class="material-symbols-outlined text-slate-700">description</span>
                <span class="font-bold">DocManager</span>
            </div>
            <div class="flex items-center gap-3">
                <a href="@Url.Action("Index","Home")"
                   class="px-4 py-2 rounded-lg text-sm font-medium text-slate-600 hover:text-slate-900">
                    Назад к доске
                </a>
                <button type="submit"
                        form="editDocumentForm"
                        class="px-4 py-2 rounded-lg bg-slate-800 text-white text-sm font-medium hover:bg-slate-900">
                    Сохранить
                </button>
                <form method="post" action="/Documents/@Model.Id/next-stage" class="inline">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 flex items-center gap-2">
                        <span class="material-symbols-outlined text-[18px]">send</span>
                        Отправить на следующий этап
                    </button>
                </form>
            </div>
        </div>
    </header>

    <main class="flex-1 px-6 py-8 flex justify-center">
        <div class="w-full max-w-6xl space-y-6">
            <div class="flex items-end justify-between gap-4">
                <div>
                    <div class="text-sm text-slate-500">Документ #@Model.Id</div>
                    <h1 class="text-2xl font-bold">Редактирование документа</h1>
                    <div class="mt-1 text-sm text-slate-600">Текущий статус: <span class="font-semibold">@Model.Status</span></div>
                </div>
            </div>

            @if (TempData["ErrorMessage"] is string err && !string.IsNullOrWhiteSpace(err))
            {
                <div class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800">
                    @err
                </div>
            }

            <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 items-start">
                <div class="lg:col-span-7 xl:col-span-8">
                    <section class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm mb-6">
                        <div class="flex items-center justify-between gap-4 mb-4">
                            <div class="flex items-center gap-2">
                                <span class="material-symbols-outlined text-blue-600">smart_toy</span>
                                <h2 class="text-sm font-bold uppercase tracking-widest text-slate-600">ИИ рекомендации</h2>
                            </div>
                            <div class="text-xs text-slate-500">Имитация извлечения полей</div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                            @foreach (var s in Model.AiSuggestions)
                            {
                                var isHigh = s.Confidence >= 80;
                                <div class="rounded-xl border @(isHigh ? "border-emerald-200 bg-emerald-50/60" : "border-amber-200 bg-amber-50/70") px-4 py-3">
                                    <div class="flex items-start justify-between gap-3">
                                        <div>
                                            <div class="text-[10px] uppercase tracking-widest font-bold text-slate-500">@s.Label</div>
                                            <div class="mt-1 text-sm font-medium text-slate-900 break-words">@s.SuggestedValue</div>
                                            <div class="mt-2 text-xs text-slate-600">Уверенность: <span class="font-semibold">@s.Confidence%</span></div>
                                        </div>
                                        <button type="button"
                                                class="shrink-0 px-3 py-1.5 rounded-lg text-xs font-semibold @(isHigh ? "bg-emerald-600 text-white hover:bg-emerald-700" : "bg-amber-600 text-white hover:bg-amber-700")"
                                                data-ai-apply
                                                data-field="@s.FieldKey"
                                                data-value="@s.SuggestedValue">
                                            Применить
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </section>

                    <form id="editDocumentForm" method="post" asp-action="Edit" class="space-y-6">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div asp-validation-summary="ModelOnly" class="rounded-xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-800"></div>

                        <section class="bg-white rounded-xl border border-slate-200 p-6 shadow-sm space-y-5">
                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                <div class="md:col-span-2">
                                    <label asp-for="Title" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Название</label>
                                    <input asp-for="Title" id="field-title" class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5 focus:ring-2 focus:ring-blue-600 focus:border-blue-600" />
                                    <span asp-validation-for="Title" class="text-xs text-red-600"></span>
                                </div>

                                <div>
                                    <label asp-for="Type" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Тип</label>
                                    <select asp-for="Type"
                                            id="field-type"
                                            asp-items="Html.GetEnumSelectList<DocumentType>()"
                                            class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5 focus:ring-2 focus:ring-blue-600 focus:border-blue-600">
                                        <option value="">Выберите тип</option>
                                    </select>
                                    <span asp-validation-for="Type" class="text-xs text-red-600"></span>
                                </div>

                                <div>
                                    <label asp-for="DueDate" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Дата</label>
                                    <input asp-for="DueDate" id="field-duedate" class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5 focus:ring-2 focus:ring-blue-600 focus:border-blue-600" />
                                    <span asp-validation-for="DueDate" class="text-xs text-red-600"></span>
                                </div>
                            </div>

                            <div>
                                <label asp-for="Description" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Описание</label>
                                <textarea asp-for="Description" id="field-description" rows="4" class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5 focus:ring-2 focus:ring-blue-600 focus:border-blue-600"></textarea>
                                <span asp-validation-for="Description" class="text-xs text-red-600"></span>
                            </div>

                            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                                <div>
                                    <label asp-for="Priority" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Приоритет</label>
                                    <select asp-for="Priority" id="field-priority" class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5 focus:ring-2 focus:ring-blue-600 focus:border-blue-600">
                                        <option value="">Не выбран</option>
                                        <option value="1">Низкий</option>
                                        <option value="2">Средний</option>
                                        <option value="3">Высокий</option>
                                    </select>
                                    <span asp-validation-for="Priority" class="text-xs text-red-600"></span>
                                </div>

                                <div>
                                    <label asp-for="Tags" class="block text-xs uppercase tracking-wider font-bold text-slate-500">Теги</label>
                                    <input asp-for="Tags" id="field-tags" class="mt-1 w-full rounded-lg border-slate-300 bg-slate-50 text-sm px-4 py-2.5 focus:ring-2 focus:ring-blue-600 focus:border-blue-600" placeholder="Например: финансы,2024" />
                                    <span asp-validation-for="Tags" class="text-xs text-red-600"></span>
                                </div>
                            </div>
                        </section>
                    </form>
                </div>

                <div class="lg:col-span-5 xl:col-span-4">
                    <section class="sticky top-[88px] bg-white rounded-xl border border-slate-200 shadow-sm overflow-hidden">
                        <div class="px-4 py-3 border-b border-slate-200 bg-slate-50 flex items-center justify-between">
                            <div class="text-sm font-semibold text-slate-700">Превью документа</div>
                            @if (!string.IsNullOrWhiteSpace(Model.FileUrl))
                            {
                                <a class="text-xs text-slate-500 hover:text-blue-600" href="@Model.FileUrl" target="_blank">Открыть</a>
                            }
                        </div>
                        <div class="bg-slate-100 p-3">
                            @if (string.IsNullOrWhiteSpace(Model.FileUrl))
                            {
                                <div class="h-[520px] flex items-center justify-center text-sm text-slate-500">
                                    Файл не загружен
                                </div>
                            }
                            else if (string.Equals(Model.FileKind, "image", StringComparison.OrdinalIgnoreCase))
                            {
                                <div class="h-[520px] rounded-lg border border-slate-200 bg-white flex items-center justify-center p-3 overflow-auto">
                                    <img class="max-h-full max-w-full object-contain rounded"
                                         src="@Model.FileUrl"
                                         alt="Превью документа" />
                                </div>
                            }
                            else if (string.Equals(Model.FileKind, "pdf", StringComparison.OrdinalIgnoreCase))
                            {
                                <iframe class="w-full h-[520px] rounded-lg border border-slate-200 bg-white"
                                        src="@Model.FileUrl"></iframe>
                            }
                            else
                            {
                                <div class="h-[520px] flex items-center justify-center text-sm text-slate-500 text-center px-4">
                                    Превью недоступно для этого типа файла. Нажмите «Открыть», чтобы скачать/просмотреть файл.
                                </div>
                            }
                        </div>
                    </section>
                </div>
            </div>
        </div>
    </main>

    <script>
        (function () {
            function setValue(selector, value) {
                const el = document.querySelector(selector);
                if (!el) return;
                el.value = value;
                el.dispatchEvent(new Event("input", { bubbles: true }));
                el.dispatchEvent(new Event("change", { bubbles: true }));
                el.focus();
            }

            document.querySelectorAll("[data-ai-apply]").forEach((btn) => {
                btn.addEventListener("click", () => {
                    const field = btn.getAttribute("data-field");
                    const value = btn.getAttribute("data-value") || "";

                    switch ((field || "").toLowerCase()) {
                        case "title":
                            setValue("#field-title", value);
                            break;
                        case "type":
                            setValue("#field-type", value);
                            break;
                        case "duedate":
                            setValue("#field-duedate", value);
                            break;
                        case "description":
                            setValue("#field-description", value);
                            break;
                        case "priority":
                            setValue("#field-priority", value);
                            break;
                        case "tags":
                            setValue("#field-tags", value);
                            break;
                    }
                });
            });
        })();
    </script>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>

